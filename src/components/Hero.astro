---
import { contacts } from "@/content";
---

<section class="relative overflow-hidden bg-paper">
  <!-- мягкий пятна-градиент для глубины -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-40 -right-40 w-[700px] h-[700px] rounded-full bg-cream/60 blur-3xl"></div>
    <div class="absolute top-1/2 -left-40 w-[500px] h-[500px] rounded-full bg-sand/50 blur-3xl"></div>
  </div>

  <div class="relative container-x pt-36 pb-20 md:pt-44 md:pb-28">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.25em] text-accent mb-6">
        Эксперт по недвижимости · Москва
      </p>
      <h1 class="font-display text-5xl md:text-7xl leading-[1.05] mb-6 text-ink">
        Помогаю выгодно и&nbsp;безопасно
        <span class="italic text-accent">продавать и&nbsp;покупать</span>
        недвижимость в&nbsp;Москве
      </h1>
      <p class="text-lg md:text-xl text-ink-soft leading-relaxed max-w-2xl mb-10">
        14 лет в&nbsp;продажах и&nbsp;маркетинге, 4&nbsp;года в&nbsp;недвижимости. Аттестованный
        агент Гильдии риэлторов Москвы. Работаю с&nbsp;командой юристов и&nbsp;ипотечных брокеров.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href={contacts.whatsapp}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-ink text-paper font-medium hover:bg-accent transition"
        >
          Записаться на консультацию
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center px-7 py-4 border border-line text-ink hover:border-accent hover:text-accent transition"
        >
          Посмотреть услуги
        </a>
      </div>
      <p class="text-sm text-ink-mute mt-6">
        Первая консультация — бесплатно, 30–40&nbsp;минут.
      </p>
    </div>
  </div>
</section>
