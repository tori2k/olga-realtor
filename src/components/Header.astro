---
import { contacts } from "@/content";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const links = [
  { href: `${base}/#about`, label: "Обо мне" },
  { href: `${base}/sell`, label: "Продать" },
  { href: `${base}/buy`, label: "Купить" },
  { href: `${base}/new-buildings`, label: "Новостройки" },
  { href: `${base}/#testimonials`, label: "Отзывы" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  const h = href.replace(/\/$/, "");
  if (h.includes("#")) return false;
  return h === path || (h !== base && path.startsWith(h));
};
---

<header class="absolute top-0 left-0 right-0 z-30">
  <div class="container-x flex items-center justify-between py-6">
    <a href={base || "/"} class="font-display text-xl tracking-wide text-ink hover:text-accent transition">
      Ольга&nbsp;Левчук
    </a>
    <nav class="hidden md:flex items-center gap-7 text-sm">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "transition",
              isActive(l.href) ? "text-accent" : "text-ink-soft hover:text-accent",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
    <a
      href={contacts.phoneHref}
      class="hidden md:inline-block text-sm text-ink hover:text-accent transition tabular-nums"
    >
      {contacts.phone}
    </a>
  </div>
</header>
