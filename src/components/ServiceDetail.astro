---
import { contacts, services } from "@/content";

interface Props {
  serviceId: string;
}

const { serviceId } = Astro.props;
const svc = services.find((s) => s.id === serviceId);
if (!svc) throw new Error(`Service ${serviceId} not found`);
---

<section class="relative overflow-hidden bg-paper">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full bg-cream/60 blur-3xl"></div>
  </div>
  <div class="relative container-x pt-36 pb-12 md:pt-40 md:pb-16">
    <p class="text-xs uppercase tracking-[0.25em] text-accent mb-6">{svc.kicker}</p>
    <h1 class="font-display text-4xl md:text-6xl leading-[1.05] text-ink max-w-4xl">
      {svc.title}
    </h1>
    <p class="text-lg md:text-xl text-ink-soft leading-relaxed max-w-2xl mt-6">
      {svc.lead}
    </p>
  </div>
</section>

<section class="py-16 md:py-24 bg-paper">
  <div class="container-x">
    {
      svc.points && (
        <div class="grid md:grid-cols-12 gap-8 md:gap-16">
          <div class="md:col-span-4">
            <p class="text-xs uppercase tracking-[0.25em] text-accent mb-4">Что входит</p>
            <h2 class="font-display text-3xl md:text-4xl leading-tight text-ink">
              Этапы работы
            </h2>
          </div>
          <div class="md:col-span-8">
            <ol class="divide-y divide-line border-y border-line">
              {svc.points.map((p, i) => (
                <li class="flex gap-6 py-5">
                  <span class="font-display text-2xl text-accent tabular-nums flex-none w-10">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="text-ink-soft leading-relaxed pt-1">{p}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      )
    }

    {
      svc.packages && (
        <div class="grid md:grid-cols-12 gap-8 md:gap-16">
          <div class="md:col-span-4">
            <p class="text-xs uppercase tracking-[0.25em] text-accent mb-4">Форматы</p>
            <h2 class="font-display text-3xl md:text-4xl leading-tight text-ink">
              Два пакета на выбор
            </h2>
          </div>
          <div class="md:col-span-8 space-y-8">
            {svc.packages.map((pkg) => (
              <div class="bg-cream/40 border border-line p-8 md:p-10">
                <h3 class="font-display text-2xl md:text-3xl mb-2 text-ink">{pkg.name}</h3>
                <p class="text-ink-soft mb-6 italic">{pkg.desc}</p>
                <ul class="space-y-3">
                  {pkg.steps.map((s) => (
                    <li class="flex gap-3 text-ink-soft leading-relaxed">
                      <span class="text-accent flex-none mt-1.5">·</span>
                      <span>{s}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<section class="py-16 md:py-24 bg-cream/50">
  <div class="container-x text-center max-w-2xl mx-auto">
    <p class="text-xs uppercase tracking-[0.25em] text-accent mb-5">Следующий шаг</p>
    <h2 class="font-display text-3xl md:text-5xl leading-tight text-ink mb-6">
      Обсудим вашу задачу — бесплатно
    </h2>
    <p class="text-ink-soft mb-10">
      Расскажите коротко о ситуации в WhatsApp или Telegram. Отвечу в течение часа в рабочее время.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href={contacts.whatsapp}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-ink text-paper hover:bg-accent transition"
      >
        Написать в WhatsApp
        <span aria-hidden="true">→</span>
      </a>
      <a
        href={contacts.telegram}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center px-7 py-4 border border-line text-ink hover:border-accent hover:text-accent transition bg-paper"
      >
        Написать в Telegram
      </a>
    </div>
  </div>
</section>
