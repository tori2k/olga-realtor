---
import { services } from "@/content";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const links: Record<string, string> = {
  sell: `${base}/sell`,
  buy: `${base}/buy`,
  "new-buildings": `${base}/new-buildings`,
};
---

<section id="services" class="py-24 md:py-32 bg-sand/40">
  <div class="container-x">
    <div class="max-w-2xl mb-14">
      <p class="text-xs uppercase tracking-[0.25em] text-accent mb-5">Услуги</p>
      <h2 class="font-display text-4xl md:text-5xl leading-tight text-ink">
        Три направления — для разных задач
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {
        services.map((svc) => (
          <a
            href={links[svc.id]}
            class="group relative flex flex-col bg-paper border border-line p-8 md:p-10 transition duration-300 hover:bg-ink hover:border-ink hover:-translate-y-1 hover:shadow-xl"
          >
            <div class="mb-6">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-full border border-accent/40 bg-cream/50 text-accent group-hover:bg-accent group-hover:border-accent group-hover:text-paper transition duration-300">
                {svc.id === "sell" && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 21V11l9-7 9 7v10" />
                    <path d="M9 21v-7h6v7" />
                    <path d="M14 7l4-4M18 3h3v3" />
                  </svg>
                )}
                {svc.id === "buy" && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="14" r="5" />
                    <path d="M13 10l7-7M17 3h3v3M16 6l3 3" />
                  </svg>
                )}
                {svc.id === "new-buildings" && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 21h18" />
                    <path d="M5 21V7l5-4 5 4v14" />
                    <path d="M15 21V11l4 2v8" />
                    <path d="M8 9h0M8 13h0M8 17h0M12 9h0M12 13h0M12 17h0" stroke-width="2.5" />
                  </svg>
                )}
              </div>
            </div>

            <p class="text-xs uppercase tracking-[0.25em] text-accent mb-3 group-hover:text-accent-soft transition">
              {svc.kicker}
            </p>
            <h3 class="font-display text-2xl md:text-3xl leading-tight mb-4 text-ink group-hover:text-paper transition">
              {svc.title}
            </h3>
            <p class="text-ink-soft leading-relaxed mb-8 flex-1 group-hover:text-paper/80 transition">
              {svc.lead}
            </p>

            <span class="inline-flex items-center justify-between gap-2 pt-5 border-t border-line text-ink group-hover:border-paper/20 group-hover:text-accent-soft transition">
              <span class="font-medium">Подробнее</span>
              <span
                aria-hidden="true"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-cream/60 text-ink group-hover:bg-accent group-hover:text-paper group-hover:translate-x-1 transition duration-300"
              >
                →
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
