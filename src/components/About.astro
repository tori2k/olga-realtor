---
import { stats } from "@/content";
const olgaPhoto = `${import.meta.env.BASE_URL}/images/olga.png`.replace(/\/+/g, "/");
---

<section id="about" class="py-24 md:py-32 bg-cream">
  <div class="container-x">
    <div class="grid md:grid-cols-12 gap-12 lg:gap-20 items-start">
      <!-- portrait -->
      <div class="md:col-span-5">
        <div class="relative aspect-[4/5] overflow-hidden bg-sand">
          <img
            src={olgaPhoto}
            alt="Ольга Левчук"
            class="h-full w-full object-cover object-top"
            loading="lazy"
          />
        </div>
      </div>

      <!-- text -->
      <div class="md:col-span-7">
        <p class="text-xs uppercase tracking-[0.25em] text-accent mb-5">Обо мне</p>
        <h2 class="font-display text-4xl md:text-5xl leading-tight mb-8">
          Меня зовут Ольга Левчук
        </h2>
        <div class="space-y-5 text-ink-soft text-lg leading-relaxed">
          <p>
            В недвижимости я с 2021 года, до этого 14 лет работала в продажах
            и маркетинге — этот опыт помогает в самой сложной части риелторской
            работы: продать вашу квартиру дороже и быстрее, чем у соседей.
          </p>
          <p>
            Прохожу обучения у ведущих экспертов рынка, получила аттестат
            Гильдии риэлторов Москвы. Работаю не одна — за моей спиной
            команда <span class="text-ink">Welcome 24</span>: юрист по недвижимости,
            ипотечный и страховой брокеры, налоговый консультант. К каждой
            сделке подключаются те, кто реально нужен.
          </p>
        </div>

        <!-- stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8 mt-12 pt-10 border-t border-line">
          {
            stats.map((s) => (
              <div>
                <div class="font-display text-4xl md:text-5xl text-accent leading-none mb-2">
                  {s.value}
                </div>
                <div class="text-sm text-ink-soft whitespace-pre-line leading-snug">
                  {s.label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
