---
import { faq } from "@/content";
---

<section id="faq" class="py-24 md:py-32 bg-sand/40">
  <div class="container-x">
    <div class="grid md:grid-cols-12 gap-12 lg:gap-20">
      <div class="md:col-span-4">
        <p class="text-xs uppercase tracking-[0.25em] text-accent mb-5">Вопросы</p>
        <h2 class="font-display text-4xl md:text-5xl leading-tight mb-6">
          Частые вопросы
        </h2>
        <p class="text-ink-soft leading-relaxed">
          Не нашли свой? Напишите в&nbsp;Telegram или WhatsApp — отвечу лично.
        </p>
      </div>
      <div class="md:col-span-8">
        <div class="divide-y divide-line border-y border-line">
          {
            faq.map((item, i) => (
              <details class="group" open={i === 0}>
                <summary class="flex items-start justify-between gap-6 cursor-pointer py-6 list-none">
                  <span class="font-display text-xl md:text-2xl leading-snug pr-4">
                    {item.q}
                  </span>
                  <span
                    class="flex-none w-8 h-8 border border-line flex items-center justify-center text-accent text-xl transition group-open:rotate-45"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <p class="pb-7 text-ink-soft leading-relaxed">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
